# ============================================
# Backup Fortress — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Comma-separated paths to files/directories to back up.
# Relative paths resolve from where the script is executed.
TARGETS=./projects,./documents,./config/settings.json

# Your Supabase Project URL
# Found at: Project Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Service Role Key
# Found at: Project Settings > API > service_role key
# WARNING: This grants admin access. Keep it secret.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example

# The Supabase Storage bucket name to upload into
SUPABASE_BUCKET=my-backups

# Encryption password for AES-256-GCM.
# You will need this to decrypt your backup later.
# Use a long, random passphrase (32+ characters recommended).
ENC_PASSWORD=your-very-strong-random-encryption-passphrase
